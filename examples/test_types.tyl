const v1: float = 3.14f;
let v2: f64 = 2.718;
const v3: int = 1000;
let v4: i8 = (i8)v1;

print(v1);
print(v2);
print(v3);
print(v4);

let sum: f64 = v1 + v2;
print(sum);

// v3 = 2000; // This should fail semantic analysis if we ran it, as v3 is const
print((int)v2);
print((char)65);

let a: int = 10;
print(++a);   // pre-increment
print(a++);   // post-increment
print(a);     // verify final value

let x: int = 5;
let y: float = 2.5;
let z: f64 = x + y;   // should promote int -> float/double
print(z);

let result: float = (v1 + v2) * 2.0 - 1.0;
print(result);

let int_from_float: int = (int)3.99;   // should truncate
let char_from_int: char = (char)66;
print(int_from_float);
print(char_from_int);

let bad: i8 = 300;  // out of range for i8
print(bad);

let pow_test: f64 = 2 ^ 3;
print(pow_test);  // expect 8