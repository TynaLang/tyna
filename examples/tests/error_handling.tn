import std.error as err;
import std.fs;

fn main(): i32 {
    let result = fs.open("missing.txt");

    if (result is Error) {
        print("we got an error:");
    }

    if (result is err.IOError) {
        print("ioerror:", result.path);
        return 1;
    } else {
        print("some other error");
        return 1;
    }

    print("opened");
    return 0;
}
