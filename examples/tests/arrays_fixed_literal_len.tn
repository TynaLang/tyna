fn main() {
    let arr: [i32; 3] = [1, 2, 3];
    print(arr.len);
    arr[1] = 20;
    print(arr[0], " ", arr[1], " ", arr[2]);

    let repeated: [i32; 4] = [7; 4];
    print(repeated[0], " ", repeated[3], " ", repeated.len);

    let inner: [i32; 2] = [4, 5];
    let matrix: [[i32; 2]; 2] = [inner, [6, 7]];
    print(matrix[1][0], " ", matrix[1][1]);
}
