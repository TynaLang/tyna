fn main() {
    let sum = 0;
    for (let i = 0; i < 3; i = i + 1) {
        sum = sum + i;
    }
    print(sum);

    let arr = [5, 6];
    for (elem in arr) {
        print(elem);
    }

    let s = "xy";
    for (c in s) {
        print(c);
    }

    let n = 0;
    while (n < 2) {
        print(n);
        n = n + 1;
    }

    loop {
        break;
    }
}
