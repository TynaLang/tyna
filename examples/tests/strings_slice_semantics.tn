// Regression guard for the pure str slice: value equality, concat, and
// length-based for-in (not C-string scan). Run after string/runtime changes:
//   ./build/tyna examples/tests/strings_slice_semantics.tyna && echo $?
// Expect exit 0 and no "FAIL:" lines on stdout.
//
// stdlib/std.tyna is always loaded by the compiler (String methods, runtime).

fn main(): i32 {
    // --- Value equality (must not compare struct bits) ---
    if ("hello" != "hello") {
        print("FAIL: same literal text should compare equal");
        return 1;
    }
    if ("hello" == "world") {
        print("FAIL: different literal text should not compare equal");
        return 1;
    }

    let x = "ping";
    let y = "ping";
    let z = "pong";
    if (x != y) {
        print("FAIL: same content via variables should compare equal");
        return 1;
    }
    if (x == z) {
        print("FAIL: different content via variables should not compare equal");
        return 1;
    }

    if ("" != "") {
        print("FAIL: empty strings should compare equal");
        return 1;
    }
    if ("" == "a") {
        print("FAIL: empty vs non-empty should not compare equal");
        return 1;
    }

    // --- Heap concat still matches by value ---
    let joined = "foo".concat("bar");
    if (joined != "foobar") {
        print("FAIL: concat result should equal literal by value");
        return 1;
    }
    if ("".concat("") != "") {
        print("FAIL: empty concat should yield empty");
        return 1;
    }

    // --- for-in uses slice length (index 0..len-1), not trailing NUL scan ---
    let s = "ABC";
    let count: i64 = 0;
    for (ch in s) {
        count = count + 1;
    }
    if (count != 3) {
        print("FAIL: for-in over str should visit len code units");
        return 1;
    }

    let empty = "";
    let ec: i64 = 0;
    for (c in empty) {
        ec = ec + 1;
    }
    if (ec != 0) {
        print("FAIL: for-in over empty str should run zero times");
        return 1;
    }

    print("strings_slice_semantics: all checks passed");
    return 0;
}
