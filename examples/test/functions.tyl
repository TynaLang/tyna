// Functions: definition, recursion, mutual recursion
def add(x:int, y:int):int {
  return x + y;
}
def fact(n:int):int {
  if (n <= 1) return 1;
  return n * fact(n-1);
}
def is_even(n:int):bool;
def is_odd(n:int):bool;
def is_even(n:int):bool {
  if (n == 0) return true;
  return is_odd(n-1);
}
def is_odd(n:int):bool {
  if (n == 0) return false;
  return is_even(n-1);
}
print(add(2,3)); // 5
print(fact(5)); // 120
print(is_even(4)); // true
print(is_odd(7)); // true