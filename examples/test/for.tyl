fn main() {
    print("--- C-style for ---");
    for (let i = 0; i < 3; i = i + 1) {
        print(i);
    }

    print("--- For-in array ---");
    let arr = [10, 20, 30];
    for (x in arr) {
        print(x);
    }

    print("--- For-in string ---");
    let s = "abc";
    for (c in s) {
        print(c); // c is i8 (char)
    }
}
