struct SourceLocation {
    file: FileId,
    offset: u32, 
}

struct SourceSpan {
    start: SourceLocation,
    end: SourceLocation,
}

impl SourceSpan {
    fn empty(): SourceSpan {
        return SourceSpan {
            start: SourceLocation { file: FileId { id: 0 }, offset: 0 },
            end: SourceLocation { file: FileId { id: 0 }, offset: 0 },
        };
    }
}